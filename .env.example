# Supabase 项目地址
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase 服务端 key
# 兼容 Vercel Marketplace 常见命名：SUPABASE_KEY
SUPABASE_KEY=sb_secret_...

# OpenRouter API Key（在 https://openrouter.ai 获取）
OPENROUTER_API_KEY=sk-or-v1-...

# 会话加密密钥（至少 16 位随机字符串）
AUTH_SECRET=your-random-secret-here

# 默认邀请码（逗号分隔，首次启动时自动写入数据库）
DEFAULT_INVITE_CODES=yourcode

# 应用基础 URL（用于 OpenRouter 来源标识）
OPENROUTER_SITE_URL=https://your-app.vercel.app

# 应用名称（显示在 OpenRouter 控制台）
OPENROUTER_APP_NAME=OpenRouter Translator
